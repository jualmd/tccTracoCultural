# URL da API — descomente a linha correta para o seu ambiente:
#
# Android Emulator (padrão automático, não precisa definir):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1
#
# iOS Simulator ou Web (padrão automático, não precisa definir):
# EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
#
# Dispositivo físico (substitua pelo IP da máquina na rede local):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8080/api/v1
